# ===== Server =====
PORT=3001

# CORS uchun ruxsat etilgan domenlar (vergul bilan ajratilgan)
CORS_ORIGINS=http://localhost:3000,https://climavent.uz

# ===== Database (Postgres) =====
POSTGRES_HOST=your-db-host
POSTGRES_PORT=5432
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=your-db-name

# ===== JWT (admin) =====
ACCESS_TOKEN_KEY=change-me
ACCESS_TOKEN_TIME=15h
REFRESH_TOKEN_KEY=change-me
REFRESH_TOKEN_TIME=15d

# ===== JWT (user) =====
ACCESS_TOKEN_KEY_USER=change-me
ACCESS_TOKEN_TIME_USER=7d
REFRESH_TOKEN_KEY_USER=change-me
REFRESH_TOKEN_TIME_USER=30d

# ===== SMS (Eskiz) =====
SMS_PASSWORD=your-eskiz-password
SMS_LOGIN=your-eskiz-login
API_BASE_URL_SMS=https://notify.eskiz.uz/api
WEB_HOOK_URL=

# ===== Mailer =====
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILDEV_USER=your-email
MAILDEV_PASS=your-app-password

# ===== OTP crypto =====
crypt_password=change-me

# ===== Cloudflare R2 =====
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
